@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <h1 class="text-center mb-4" data-aos="fade-up">Our Services</h1>

    <p class="text-center mb-5" data-aos="fade-up" data-aos-delay="200">
        We provide high-quality solutions tailored to modern business needs.
    </p>

    <div class="row">

        <!-- Service 1 -->
        <div class="col-md-4 mb-4" data-aos="fade-up">
            <div class="card p-4 text-center h-100">
                <i class="fa fa-code fa-3x text-primary mb-3"></i>
                <h4>Software Development</h4>
                <p>
                    We design and build custom applications tailored to your business operations,
                    including stock systems, ERP tools, and logistics platforms.
                </p>
            </div>
        </div>

        <!-- Service 2 -->
        <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="200">
            <div class="card p-4 text-center h-100">
                <i class="fa fa-weight-scale fa-3x text-success mb-3"></i>
                <h4>Weighing System Integration</h4>
                <p>
                    We integrate industrial weighing systems with software to provide accurate,
                    real-time tracking, reporting, and automation.
                </p>
            </div>
        </div>

        <!-- Service 3 -->
        <div class="col-md-4 mb-4" data-aos="fade-up" data-aos-delay="400">
            <div class="card p-4 text-center h-100">
                <i class="fa fa-robot fa-3x text-warning mb-3"></i>
                <h4>AI & Automation</h4>
                <p>
                    Our AI-powered solutions help predict, automate, and optimize your operations,
                    improving efficiency and reducing human error.
                </p>
            </div>
        </div>

    </div>

    <!-- CTA Section -->
    <div class="text-center mt-5" data-aos="zoom-in">
        <h3>Ready to Transform Your Business?</h3>
        <a href="/Contact" class="btn btn-warning mt-3">Request a Quote</a>
    </div>

</div>