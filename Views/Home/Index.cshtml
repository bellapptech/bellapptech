@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="hero">
    <h1 data-aos="fade-up">Smart Software for Logistics & Weighing</h1>
    <p data-aos="fade-up" data-aos-delay="200">
        Powerful solutions for businesses in Africa
    </p>
    <a href="/Products" class="btn btn-main mt-3" data-aos="zoom-in">Explore Products</a>
</div>

<div class="container mt-5">
    <h2 class="text-center mb-4">Our Services</h2>

    <div class="row">

        <div class="col-md-4 mb-3" data-aos="fade-up">
            <div class="card p-4 text-center">
                <i class="fa fa-code fa-3x mb-3 text-primary"></i>
                <h5>Software Development</h5>
                <p>Custom enterprise applications</p>
            </div>
        </div>

        <div class="col-md-4 mb-3" data-aos="fade-up" data-aos-delay="200">
            <div class="card p-4 text-center">
                <i class="fa fa-weight-scale fa-3x mb-3 text-success"></i>
                <h5>Weighing Systems</h5>
                <p>Industrial scale integrations</p>
            </div>
        </div>

        <div class="col-md-4 mb-3" data-aos="fade-up" data-aos-delay="400">
            <div class="card p-4 text-center">
                <i class="fa fa-robot fa-3x mb-3 text-warning"></i>
                <h5>AI & Automation</h5>
                <p>Smart predictions & automation</p>
            </div>
        </div>

    </div>
